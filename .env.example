# ─── Supabase (API / Netlify Functions) ───────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/<project-id>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret (HS256) — verificação local do token na API (sem round-trip ao Auth). Settings → API → JWT Settings.
SUPABASE_JWT_SECRET=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Mesmos valores acima, com prefixo VITE_ para exposição ao browser
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── CORS (API Express) ───────────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas.
# Em produção no Netlify (mesmo domínio) não é necessário.
# Em dev local: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── API URL (Frontend) ───────────────────────────────────────────────────────
# OBRIGATÓRIA. Em produção no Netlify: /api/v1 (path relativo, mesmo domínio).
# Em dev local: http://localhost:3001/api/v1
VITE_API_URL=

# ─── Token interno (opcional) ─────────────────────────────────────────────────
# Protege a background function de import (banking-import-background). Quando
# setado, o webhook envia no header x-internal-token e a function valida.
INTERNAL_FUNCTION_TOKEN=

# ─── Webhook Pluggy (opcional) ─────────────────────────────────────────────────
# Segredo compartilhado para validar o webhook da Pluggy. Registre a URL do
# webhook na Pluggy com ?token=<secret>. Se ausente, a validação é pulada.
WEBHOOK_SECRET=

# ─── Pluggy (Open Finance) ─────────────────────────────────────────────────────
# Credenciais da Pluggy — OBRIGATÓRIAS para o Open Finance. Painel da Pluggy.
# NUNCA versionar valores reais (use as env vars da Netlify em produção).
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# Opcionais (têm default no código):
PLUGGY_WEBHOOK_URL=
PLUGGY_CONNECTOR_IDS=
