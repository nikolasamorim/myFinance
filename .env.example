# ─── Supabase (API / Netlify Functions) ───────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/<project-id>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Mesmos valores acima, com prefixo VITE_ para exposição ao browser
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── CORS (API Express) ───────────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas.
# Em produção no Netlify (mesmo domínio) não é necessário.
# Em dev local: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── API URL (Frontend) ───────────────────────────────────────────────────────
# Em produção no Netlify deixe vazio (frontend e API no mesmo domínio — path relativo /api).
# Em dev local aponte para: http://localhost:3001
VITE_API_URL=
