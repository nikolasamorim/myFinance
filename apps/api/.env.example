# API — myFinance Backend
# Copie para .env e preencha antes de rodar

# Servidor
PORT=3001
NODE_ENV=development

# Supabase — obtenha em https://app.supabase.com → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# CORS — lista separada por vírgula de origens permitidas
# Inclua localhost (dev), domínios Netlify, e protocolo do app mobile
CORS_ORIGINS=http://localhost:5173,https://myfinance.netlify.app,capacitor://localhost,ionic://localhost

# Pluggy — credenciais da dashboard Pluggy
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# IDs de conectores permitidos no widget (opcional).
# Em conta TRIAL use "0" (Pluggy Bank sandbox). Em produção, remova esta variável.
PLUGGY_CONNECTOR_IDS=0
